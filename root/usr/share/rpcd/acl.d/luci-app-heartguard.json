{
	"heartguard": {
		"description": "HeartGuard Family Internet Manager",
		"read": {
			"uci": ["heartguard"],
			"ubus": {
				"heartguard": ["status", "get_devices", "get_profiles", "get_log"],
				"network.interface": ["status"],
				"network": ["get_proto_handlers"]
			},
			"file": {
				"/etc/heartguard/*": ["read"],
				"/var/log/heartguard.log": ["read"],
				"/proc/net/arp": ["read"]
			}
		},
		"write": {
			"uci": ["heartguard"],
			"ubus": {
				"heartguard": ["apply", "reload", "block_device", "unblock_device"]
			},
			"file": {
				"/etc/heartguard/*": ["write"]
			}
		}
	}
}
