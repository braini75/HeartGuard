{
	"heartguard": {
		"description": "HeartGuard Family Internet Manager",
		"read": {
			"uci": ["heartguard"],
			"ubus": {
				"heartguard": ["status", "log"],
				"network.interface": ["status"],
				"luci": ["getHostHints"]
			},
			"file": {
				"/etc/heartguard/*": ["read"],
				"/proc/net/arp": ["read"]
			}
		},
		"write": {
			"uci": ["heartguard"],
			"ubus": {
				"heartguard": ["reload"]
			},
			"file": {
				"/etc/heartguard/*": ["write"]
			}
		}
	}
}
